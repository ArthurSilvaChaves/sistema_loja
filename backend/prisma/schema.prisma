generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Product {
  id        Int    @id @default(autoincrement())
  name      String
  price     Float
  inventory Int    @default(0)
}

model Employee {
  id       Int    @id @default(autoincrement())
  cpf      String @unique
  name     String
  telefone String
  email    String
}